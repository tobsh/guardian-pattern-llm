{
  "name": "@guardian-demo/chat-web",
  "version": "0.1.0",
  "private": true,
  "description": "guardian-demo chat frontend — Next.js SPA, Cognito Hosted UI, talks to the private Guardian API",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
