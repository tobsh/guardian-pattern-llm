{
  "name": "@guardian-demo/guardian-poc",
  "version": "0.1.0",
  "private": true,
  "description": "Guardian Layer PoC — constitutional classifier on Bedrock AgentCore",
  "type": "module",
  "main": "dist/handler.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/handler.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "eval": "tsx src/eval/run.ts",
    "eval:compare": "tsx src/eval/compare.ts"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.33.0",
    "@aws-sdk/client-bedrock-agentcore": "^3.1038.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1038.0",
    "@aws-sdk/client-cloudformation": "^3.1038.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1038.0",
    "@aws-sdk/client-s3": "^3.1038.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-functional": "^9.0.4",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
